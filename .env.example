# SerpAPI — replaces deprecated Google Custom Search JSON API
# Sign up free at serpapi.com (100 searches/month free, $50/mo for 5,000)
SERP_API_KEY=your_serpapi_key_here

# Google Maps Places API (for discovery)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Firebase
FIREBASE_PROJECT_ID=carpilothq
FIREBASE_SERVICE_ACCOUNT_PATH=./service-account.json

# Firebase Web SDK (for dashboard)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=carpilothq.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=carpilothq
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=carpilothq.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Scraper Settings
SCRAPER_CONCURRENCY=10
SCRAPER_DELAY_MS=500
SCRAPER_DELAY_JITTER_MS=200

# Proxy Settings (comma-separated list or rotating endpoint)
PROXY_LIST=
PROXY_ROTATING_ENDPOINT=

# Dashboard
NEXT_PUBLIC_BASE_URL=http://localhost:3000
